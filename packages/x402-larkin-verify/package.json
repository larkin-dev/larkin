{
  "name": "@larkinsh/verify",
  "version": "0.0.1",
  "description": "Verify Larkin Ed25519-signed receipts. Zero dependency on Larkin's API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "larkin-verify": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "x402",
    "larkin",
    "ed25519",
    "verify",
    "receipt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/larkin-dev/larkin.git",
    "directory": "packages/x402-larkin-verify"
  },
  "homepage": "https://larkin.sh",
  "bugs": "https://github.com/larkin-dev/larkin/issues",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "json-canonicalize": "^1.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.4"
  }
}
