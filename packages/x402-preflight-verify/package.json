{
  "name": "@preflight/verify",
  "version": "0.0.1",
  "description": "Verify Preflight Ed25519-signed receipts. Zero dependency on Preflight's API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "preflight-verify": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "x402",
    "preflight",
    "ed25519",
    "verify",
    "receipt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/preflight-dev/preflight",
    "directory": "packages/x402-preflight-verify"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
