{
  "name": "@larkinsh/x402",
  "version": "1.0.3",
  "description": "Authorization middleware for the x402 agent payment protocol.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "x402",
    "agent",
    "wallet",
    "authorization",
    "larkin"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/larkin-dev/larkin.git",
    "directory": "packages/x402-larkin"
  },
  "homepage": "https://larkin.sh",
  "bugs": "https://github.com/larkin-dev/larkin/issues",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "express": "^4 || ^5",
    "hono": "^4",
    "next": "^14 || ^15"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "hono": { "optional": true },
    "next": { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "express": "^5.0.0",
    "hono": "^4.6.0",
    "next": "^15.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.4"
  }
}
